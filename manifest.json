{
    "manifest_version": 3,
    "name": "ChatGPT Prompt Sidebar",
    "version": "1.1",
    "description": "在侧边栏显示所有的提示词",
    "content_scripts": [
        {
            "matches": [
                "*://chatgpt.com/*"
            ],
            "css": [
                "styles.css"
            ],
            "js": [
                "content.js"
            ]
        }
    ]
}